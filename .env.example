APP_NAME=Fuse

PORT=9090

# Database: memory | postgres
DB_DRIVER=memory
# DB_POSTGRES_DSN=postgres://fuse:fuse@localhost:5432/fuse?sslmode=disable
# DB_MAX_OPEN_CONNS=25
# DB_MAX_IDLE_CONNS=5
# DB_CONN_MAX_LIFETIME=5m

# Object Store: memory | filesystem | s3
OBJECT_STORE_DRIVER=memory
# OBJECT_STORE_KEY_PREFIX=
# OBJECT_STORE_FS_BASE_PATH=./data/fuse
# OBJECT_STORE_S3_BUCKET=fuse-data
# OBJECT_STORE_S3_ENDPOINT=http://localhost:4566
# OBJECT_STORE_S3_REGION=us-east-1
# OBJECT_STORE_S3_ACCESS_KEY=test
# OBJECT_STORE_S3_SECRET_KEY=test
# OBJECT_STORE_S3_USE_SSL=false

# High Availability
# HA_ENABLED=false
# HA_NODE_ID=
# HA_HEARTBEAT_INTERVAL=10s
# HA_CLAIM_SWEEP_INTERVAL=5s
# HA_LEASE_TIMEOUT=30s

# LLM providers (for ai/chat and ai/agent nodes). Each provider is disabled by default.
# DefaultProvider is used when a node does not specify one.
# LLM_DEFAULT_PROVIDER=ollama
#
# Ollama (local dev, no API key needed) — OpenAI-compatible endpoint:
# LLM_OLLAMA_ENABLED=true
# LLM_OLLAMA_BASE_URL=http://localhost:11434/v1
# LLM_OLLAMA_MODEL=llama3.1
#
# OpenAI:
# LLM_OPENAI_ENABLED=false
# LLM_OPENAI_API_KEY=
# LLM_OPENAI_MODEL=gpt-4o
#
# OpenRouter (OpenAI-compatible; many models behind one interface):
# LLM_OPENROUTER_ENABLED=false
# LLM_OPENROUTER_API_KEY=
# LLM_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# LLM_OPENROUTER_MODEL=openai/gpt-4o
#
# Google Gemini (OpenAI-compatible endpoint):
# LLM_GEMINI_ENABLED=false
# LLM_GEMINI_API_KEY=
# LLM_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_GEMINI_MODEL=gemini-2.0-flash
#
# Anthropic (native protocol; Phase C):
# LLM_ANTHROPIC_ENABLED=false
# LLM_ANTHROPIC_API_KEY=
# LLM_ANTHROPIC_MODEL=claude-sonnet-4-6

LOG_FORMAT=console